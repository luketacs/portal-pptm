{
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/browser",
  "functions": {
    "api/apontamentos.js": { "maxDuration": 10 }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
