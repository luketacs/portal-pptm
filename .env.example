# Ambiente de variáveis para produção
# Copie este arquivo para .env.local e preencha os valores reais

# Chave da API Gemini (obrigatório para integração Gemini)
GEMINI_API_KEY=

# Supabase (obrigatório para criação de usuários via API serverless)
# Encontre esses valores em: Project Settings > API no Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# API Material (se aplicável)
MATERIAL_API_TOKEN=

# Outras variáveis sensíveis podem ser adicionadas aqui
